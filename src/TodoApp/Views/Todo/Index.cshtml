@model IEnumerable<TodoApp.Application.DTOs.TodoDto>

@{
    ViewData["Title"] = "Todo List";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h1>Todo List</h1>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Todo
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col">
            @if (Model.Any())
            {
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>@Html.DisplayNameFor(m => m.Title)</th>
                            <th>@Html.DisplayNameFor(m => m.Description)</th>
                            <th>@Html.DisplayNameFor(m => m.IsCompleted)</th>
                            <th>@Html.DisplayNameFor(m => m.CreatedAt)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr class="@item.IsCompleted ? "table-success" : """>
                                <td>
                                    @(item.IsCompleted ? "<s>" + Html.DisplayFor(m => item.Title) + "</s>" : Html.DisplayFor(m => item.Title))
                                </td>
                                <td>@Html.DisplayFor(m => item.Description)</td>
                                <td>
                                    <span class="badge @(item.IsCompleted ? "bg-success" : "bg-warning")">
                                        @(item.IsCompleted ? "Completed" : "Pending")
                                    </span>
                                </td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">
                                        <i class="bi bi-eye"></i> Details
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this todo?');">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info" role="alert">
                    No todos found. <a asp-action="Create">Create your first todo!</a>
                </div>
            }
        </div>
    </div>
</div>
